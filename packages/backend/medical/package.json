{
  "name": "ecodigital-backend-service",
  "version": "1.0.0",
  "description": "Backend service for the EcoDigital application, running on Cloud Run.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon --inspect server.js",
    "db:setup": "node scripts/setup-dev-db.js",
    "db:migrate": "node -e \"require('./db').runSqlFile('setup_database.sql')\"",
    "db:seed": "node -e \"require('./db').runSqlFile('seed_data.sql')\"",
    "db:reset": "npm run db:migrate && npm run db:seed",
    "db:stats": "node -e \"require('./db').getStats().then(stats => console.log(JSON.stringify(stats, null, 2)))\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "build": "echo 'Backend build placeholder'"
  },
  "author": "dogma.black",
  "license": "ISC",
  "dependencies": {
    "@google-cloud/secret-manager": "^6.1.1",
    "@google-cloud/storage": "^7.18.0",
    "@google-cloud/vertexai": "^1.10.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.68.0",
    "@opentelemetry/sdk-node": "^0.210.0",
    "@sendgrid/mail": "^8.1.6",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.0.2",
    "nodemailer": "^7.0.12",
    "pg": "^8.16.3",
    "twilio": "^5.11.2"
  },
  "devDependencies": {
    "fast-check": "^4.5.3",
    "jest": "^30.2.0",
    "nodemon": "^3.1.11",
    "supertest": "^7.2.2"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "services/**/*.js",
      "routes/**/*.js",
      "!node_modules/**"
    ],
    "testMatch": [
      "**/__tests__/**/*.js",
      "**/?(*.)+(spec|test).js"
    ]
  }
}
