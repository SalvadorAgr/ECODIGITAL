# EcoDigital Backend - Environment Configuration Template
# Copy this file to .env and configure for your environment

# ===========================================
# NODE.JS CONFIGURATION
# ===========================================
NODE_ENV=development
PORT=8080

# ===========================================
# GOOGLE CLOUD PLATFORM
# ===========================================
GOOGLE_CLOUD_PROJECT_ID=your-project-id
GOOGLE_CLOUD_REGION=us-central1

# ===========================================
# CLOUD SQL POSTGRESQL
# ===========================================
# Development (local)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ecodigital_dev
DB_USER=ecodigital_app
DB_PASSWORD=change_me_in_production

# Production (Cloud SQL)
# DB_HOST=/cloudsql/PROJECT_ID:REGION:INSTANCE_NAME
# DB_NAME=ecodigital
# DB_USER=ecodigital_app
# DB_PASSWORD=<FROM_SECRET_MANAGER>

# ===========================================
# SECURITY (USE SECRET MANAGER IN PRODUCTION)
# ===========================================
JWT_SECRET=your-jwt-secret-key-change-in-production
JWT_EXPIRES_IN=24h

# ===========================================
# CLOUD STORAGE
# ===========================================
STORAGE_BUCKET_NAME=ecodigital-storage-bucket
STORAGE_ENCRYPTION_KEY=your-32-character-encryption-key-here

# ===========================================
# VERTEX AI
# ===========================================
VERTEX_AI_LOCATION=us-central1
VERTEX_AI_MODEL=gemini-pro

# ===========================================
# EXTERNAL SERVICES
# ===========================================
# SendGrid (Email)
SENDGRID_API_KEY=your-sendgrid-api-key

# Twilio (SMS)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=your-twilio-phone-number

# ===========================================
# LOGGING & MONITORING
# ===========================================
LOG_LEVEL=info
ENABLE_REQUEST_LOGGING=true

# ===========================================
# DEVELOPMENT ONLY
# ===========================================
# Set to true to create tables on startup (development only)
CREATE_TABLES_ON_STARTUP=false
ENABLE_SQL_DEBUG=false

# Gemma Local AI Model Configuration
GEMMA_MODEL_PATH=./gemma-3-270m-it
GEMMA_MAX_TOKENS=512
GEMMA_TEMPERATURE=0.7
GEMMA_CONTEXT_WINDOW=2048

# Dashboard Configuration
DASHBOARD_CACHE_TTL=300
DASHBOARD_MAX_RECENT_PATIENTS=10
DASHBOARD_CLEANUP_INTERVAL=86400