# EcoDigital Backend - Environment Configuration
# ===========================================
# NODE.JS CONFIGURATION
# ===========================================
NODE_ENV=development
PORT=8080

# ===========================================
# GOOGLE CLOUD PLATFORM
# ===========================================
GOOGLE_CLOUD_PROJECT_ID=ecodigital-project
GOOGLE_CLOUD_REGION=us-central1

# ===========================================
# CLOUD SQL POSTGRESQL
# ===========================================
# Development (local)
DATABASE_URL=postgresql://myuser:mypassword@localhost:5432/mydatabase
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mydatabase
DB_USER=myuser
DB_PASSWORD=mypassword

# ===========================================
# SECURITY
# ===========================================
JWT_SECRET=ecodigital-jwt-secret-key-development-only-change-in-production
JWT_EXPIRES_IN=24h

# ===========================================
# CLOUD STORAGE
# ===========================================
STORAGE_BUCKET_NAME=ecodigital-storage-bucket
STORAGE_ENCRYPTION_KEY=ecodigital-32-char-encryption-key

# ===========================================
# VERTEX AI
# ===========================================
VERTEX_AI_LOCATION=us-central1
VERTEX_AI_MODEL=gemini-pro

# ===========================================
# EXTERNAL SERVICES (Optional for development)
# ===========================================
# SendGrid (Email)
# SENDGRID_API_KEY=your-sendgrid-api-key

# Twilio (SMS)
# TWILIO_ACCOUNT_SID=your-twilio-account-sid
# TWILIO_AUTH_TOKEN=your-twilio-auth-token
# TWILIO_PHONE_NUMBER=your-twilio-phone-number

# ===========================================
# LOGGING & MONITORING
# ===========================================
LOG_LEVEL=info
ENABLE_REQUEST_LOGGING=true

# ===========================================
# DEVELOPMENT ONLY
# ===========================================
CREATE_TABLES_ON_STARTUP=true
ENABLE_SQL_DEBUG=false