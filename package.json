{
  "name": "@ecodigital/pwa",
  "version": "1.0.0",
  "private": true,
  "description": "ECODIGITAL - Progressive Web Application",
  "author": "dogma.black",
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "packages/frontend/apps/web",
    "packages/frontend/core",
    "packages/frontend/component",
    "packages/frontend/i18n",
    "packages/frontend/routes",
    "packages/frontend/templates",
    "packages/frontend/track",
    "packages/frontend/native",
    "packages/common/*",
    "packages/backend/server",
    "blocksuite/*",
    "_backend"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "yarn workspace @affine/web dev",
    "build": "yarn workspace @affine/web build",
    "start": "yarn workspace @affine/web build && yarn workspace @affine/web start",
    "clean": "rm -rf node_modules packages/*/node_modules blocksuite/*/node_modules _backend/node_modules",
    "lint": "eslint --cache .",
    "lint:fix": "eslint --cache --fix .",
    "typecheck": "tsc --noEmit",
    "validate": "yarn typecheck && yarn lint"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.9.3"
  },
  "packageManager": "yarn@4.12.0"
}